{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat",       "name": "Stat",        "version": "" },
    { "type": "panel", "id": "table",      "name": "Table",       "version": "" },
    { "type": "panel", "id": "row",        "name": "Row",         "version": "" }
  ],
  "title": "ToolJet Observability",
  "description": "Frontend errors (released app vs platform) + backend API + query performance",
  "uid": "tooljet-otel-v2",
  "id": null,
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "fiscalYearStartMonth": 0,
  "tags": ["tooljet", "otel"],
  "links": [],
  "annotations": { "list": [] },

  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1
      }
    ]
  },

  "panels": [

    {
      "type": "row",
      "id": 1,
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "type": "stat",
      "id": 2,
      "title": "Released App Errors / hr",
      "description": "JS + widget + query errors on /applications/* and /embed-apps/*",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null,  "color": "green" },
            { "value": 10,    "color": "yellow" },
            { "value": 50,    "color": "red" }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "noValue": "0"
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "(sum(increase(frontend_js_errors_total{app_context=\"released_app\"}[1h])) or vector(0)) + (sum(increase(frontend_widget_errors_total{app_context=\"released_app\"}[1h])) or vector(0)) + (sum(increase(frontend_query_errors_total{app_context=\"released_app\"}[1h])) or vector(0))",
        "legendFormat": ""
      }]
    },

    {
      "type": "stat",
      "id": 3,
      "title": "Platform Errors / hr",
      "description": "JS + widget + query errors in the ToolJet builder / editor",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "green" },
            { "value": 20,   "color": "yellow" },
            { "value": 100,  "color": "red" }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "noValue": "0"
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "(sum(increase(frontend_js_errors_total{app_context=\"platform\"}[1h])) or vector(0)) + (sum(increase(frontend_widget_errors_total{app_context=\"platform\"}[1h])) or vector(0)) + (sum(increase(frontend_query_errors_total{app_context=\"platform\"}[1h])) or vector(0))",
        "legendFormat": ""
      }]
    },

    {
      "type": "stat",
      "id": 4,
      "title": "Server Query Failure Rate",
      "description": "% of backend data query executions that failed",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "green" },
            { "value": 5,    "color": "yellow" },
            { "value": 15,   "color": "red" }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "noValue": "0"
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "(sum(rate(query_failures_total[5m])) / sum(rate(query_executions_total[5m])) * 100) or vector(0)",
        "legendFormat": ""
      }]
    },

    {
      "type": "stat",
      "id": 5,
      "title": "API p95 Latency",
      "description": "95th-percentile response time across all API endpoints",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null,  "color": "green" },
            { "value": 500,   "color": "yellow" },
            { "value": 2000,  "color": "red" }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "noValue": "0"
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "histogram_quantile(0.95, sum(rate(api_duration_milliseconds_bucket[5m])) by (le)) or vector(0)",
        "legendFormat": ""
      }]
    },

    {
      "type": "row",
      "id": 10,
      "title": "Released App Health  (/applications/* and /embed-apps/*)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },

    {
      "type": "timeseries",
      "id": 11,
      "title": "JS Errors — Released Apps",
      "description": "Uncaught JS exceptions in customer-facing released apps",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(frontend_js_errors_total{app_context=\"released_app\"}[5m]))",
        "legendFormat": "JS errors"
      }]
    },

    {
      "type": "timeseries",
      "id": 12,
      "title": "Query / API Failures — Released Apps",
      "description": "Data query failures seen by end users in released apps",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(frontend_query_errors_total{app_context=\"released_app\"}[5m])) by (error_type)",
        "legendFormat": "browser: {{error_type}}"
      }, {
        "refId": "B",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(query_failures_total{is_released=\"true\"}[5m])) by (data_source_type)",
        "legendFormat": "server: {{data_source_type}}"
      }]
    },

    {
      "type": "timeseries",
      "id": 13,
      "title": "Widget Errors — Released Apps",
      "description": "Widget render failures in customer-facing apps (by widget type)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(frontend_widget_errors_total{app_context=\"released_app\"}[5m])) by (widget_type)",
        "legendFormat": "{{widget_type}}"
      }]
    },

    {
      "type": "table",
      "id": 14,
      "title": "App Success Rate (released, last 15 min)",
      "description": "Server-side query success rate per app in view/released mode",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "red" },
            { "value": 90,   "color": "yellow" },
            { "value": 99,   "color": "green" }
          ]},
          "custom": { "displayMode": "color-background" }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false },
        "sortBy": [{ "desc": false, "displayName": "Success Rate" }]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": {
          "excludeByName": { "Time": true, "__name__": true },
          "renameByName": { "app_id": "App ID", "environment": "Env", "Value": "Success Rate" }
        }}
      ],
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "app_success_rate{mode=\"view\"}",
        "instant": true,
        "legendFormat": "{{app_id}} / {{environment}}"
      }]
    },

    {
      "type": "timeseries",
      "id": 15,
      "title": "Active Users per Released App",
      "description": "Number of distinct users active in each app in the last 15 min",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 5, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "topk(10, app_active_users)",
        "legendFormat": "{{app_id}}"
      }]
    },

    {
      "type": "row",
      "id": 20,
      "title": "Platform Health  (builder, editor, settings)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },

    {
      "type": "timeseries",
      "id": 21,
      "title": "JS Errors — Platform",
      "description": "Uncaught JS exceptions in the ToolJet builder / editor / admin",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(frontend_js_errors_total{app_context=\"platform\"}[5m]))",
        "legendFormat": "JS errors"
      }]
    },

    {
      "type": "timeseries",
      "id": 22,
      "title": "Query / API Failures — Platform",
      "description": "Data query failures while editing apps (edit mode, preview mode)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(frontend_query_errors_total{app_context=\"platform\"}[5m])) by (error_type)",
        "legendFormat": "browser: {{error_type}}"
      }, {
        "refId": "B",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(query_failures_total{is_released=\"false\"}[5m])) by (data_source_type)",
        "legendFormat": "server: {{data_source_type}}"
      }]
    },

    {
      "type": "timeseries",
      "id": 23,
      "title": "Widget Errors — Platform",
      "description": "Widget render failures in the editor (by widget type)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(frontend_widget_errors_total{app_context=\"platform\"}[5m])) by (widget_type)",
        "legendFormat": "{{widget_type}}"
      }]
    },

    {
      "type": "row",
      "id": 30,
      "title": "Backend: API Performance",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 }
    },

    {
      "type": "timeseries",
      "id": 31,
      "title": "API Request Rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 5, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "topk(10, sum(rate(api_hits_total[5m])) by (route))",
        "legendFormat": "{{route}}"
      }]
    },

    {
      "type": "timeseries",
      "id": 32,
      "title": "API p95 / p50 Latency",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "histogram_quantile(0.95, sum(rate(api_duration_milliseconds_bucket[5m])) by (le))",
        "legendFormat": "p95"
      }, {
        "refId": "B",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "histogram_quantile(0.50, sum(rate(api_duration_milliseconds_bucket[5m])) by (le))",
        "legendFormat": "p50"
      }]
    },

    {
      "type": "timeseries",
      "id": 33,
      "title": "Slowest API Routes (p95)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 1, "fillOpacity": 5, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "topk(8, histogram_quantile(0.95, sum(rate(api_duration_milliseconds_bucket[5m])) by (le, route)))",
        "legendFormat": "{{route}}"
      }]
    },

    {
      "type": "row",
      "id": 40,
      "title": "Backend: Query Execution",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 }
    },

    {
      "type": "timeseries",
      "id": 41,
      "title": "Query Execution Rate (by datasource)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 41 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 5, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(query_executions_total[5m])) by (data_source_type)",
        "legendFormat": "{{data_source_type}}"
      }]
    },

    {
      "type": "timeseries",
      "id": 42,
      "title": "Query Failure Rate (by error type)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 41 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(query_failures_total[5m])) by (error_type)",
        "legendFormat": "{{error_type}}"
      }]
    },

    {
      "type": "timeseries",
      "id": 43,
      "title": "Query p95 Duration (by datasource)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 41 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 1, "fillOpacity": 5, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "histogram_quantile(0.95, sum(rate(query_duration_milliseconds_bucket[5m])) by (le, data_source_type))",
        "legendFormat": "p95 {{data_source_type}}"
      }, {
        "refId": "B",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "histogram_quantile(0.50, sum(rate(query_duration_milliseconds_bucket[5m])) by (le, data_source_type))",
        "legendFormat": "p50 {{data_source_type}}"
      }]
    },

    {
      "type": "table",
      "id": 44,
      "title": "Slowest Apps — Query Duration p95",
      "description": "Which apps are producing the slowest queries (server-side)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null,  "color": "green" },
            { "value": 1000,  "color": "yellow" },
            { "value": 5000,  "color": "red" }
          ]},
          "custom": { "displayMode": "color-background" }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false },
        "sortBy": [{ "desc": true, "displayName": "p95 (ms)" }]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": {
          "excludeByName": { "Time": true, "__name__": true },
          "renameByName": { "app_id": "App ID", "data_source_type": "Datasource", "Value": "p95 (ms)" }
        }}
      ],
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "topk(20, histogram_quantile(0.95, sum(rate(query_duration_milliseconds_bucket[10m])) by (le, app_id, data_source_type)))",
        "instant": true,
        "legendFormat": "{{app_id}} / {{data_source_type}}"
      }]
    },

    {
      "type": "table",
      "id": 45,
      "title": "Most Failing Apps (last 10 min)",
      "description": "Apps with the highest query failure count",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "green" },
            { "value": 5,    "color": "yellow" },
            { "value": 20,   "color": "red" }
          ]},
          "custom": { "displayMode": "color-background" }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false },
        "sortBy": [{ "desc": true, "displayName": "Failures" }]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": {
          "excludeByName": { "Time": true, "__name__": true },
          "renameByName": { "app_id": "App ID", "error_type": "Error Type", "mode": "Mode", "Value": "Failures" }
        }}
      ],
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "topk(20, increase(query_failures_total[10m]))",
        "instant": true,
        "legendFormat": "{{app_id}} / {{error_type}} / {{mode}}"
      }]
    },

    {
      "type": "row",
      "id": 50,
      "title": "Users & Sessions",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 }
    },

    {
      "type": "timeseries",
      "id": 51,
      "title": "Concurrent Active Users (by workspace)",
      "description": "Distinct users seen in the last 5 min per workspace",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 58 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "topk(10, users_concurrent_active{metric_type=\"workspace_total\"})",
        "legendFormat": "workspace {{workspace_id}}"
      }]
    },

    {
      "type": "timeseries",
      "id": 52,
      "title": "Login / Logout Rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 58 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 5, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(user_sessions_total[5m])) by (event_type)",
        "legendFormat": "{{event_type}}"
      }]
    },

    {
      "type": "timeseries",
      "id": 53,
      "title": "App Lifecycle Events",
      "description": "App create / update / delete / release rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 58 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 5, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(app_creations_total[5m]))",
        "legendFormat": "created"
      }, {
        "refId": "B",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(app_updates_total[5m]))",
        "legendFormat": "updated"
      }, {
        "refId": "C",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(app_deletions_total[5m]))",
        "legendFormat": "deleted"
      }, {
        "refId": "D",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(app_releases_total[5m]))",
        "legendFormat": "released"
      }]
    }

  ]
}
