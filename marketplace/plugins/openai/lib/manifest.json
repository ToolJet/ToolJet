{
  "$schema": "https://raw.githubusercontent.com/ToolJet/ToolJet/develop/plugins/schemas/manifest.schema.json",
  "title": "OpenAI plugin",
  "description": "A schema defining OpenAI datasource",
  "type": "object",
  "tj:version": "1.0.0",
  "tj:source": {
    "name": "OpenAI",
    "kind": "openai",
    "type": "api"
  },
  "properties": {
    "apiKey": {
      "type": "string",
      "title": "API Key",
      "description": "Enter your OpenAI API Key"
    }
  },
  "tj:encrypted": [
    "apiKey"
  ],
  "required": [
    "apiKey"
  ],
  "tj:ui:properties": {
    "apiKey": {
      "order": 10,
      "$ref": "#/properties/apiKey",
      "key": "apiKey",
      "label": "API Key",
      "widget": "password-v3",
      "placeholder": "sk-...",
      "help_text": "For generating API Key, visit: <a href='https://platform.openai.com/account/api-keys' target='_blank' rel='noreferrer'>OpenAI Console</a>"
    }
  }
}