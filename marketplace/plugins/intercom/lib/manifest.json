{
  "$schema": "https://raw.githubusercontent.com/ToolJet/ToolJet/develop/plugins/schemas/manifest.schema.json",
  "title": "Intercom Datasource",
  "description": "Connect to Intercom API to manage contacts, conversations, tickets, companies, articles, and more",
  "type": "api",
  "source": {
    "name": "Intercom",
    "kind": "intercom",
    "exposedVariables": { "isLoading": false, "data": {}, "rawData": {} },
    "options": {
      "access_token": { "type": "string", "encrypted": true }
    },
    "customTesting": true
  },
  "defaults": {},
  "properties": {
    "access_token": {
      "label": "Access Token",
      "key": "access_token",
      "type": "password",
      "description": "Enter your Intercom Access Token"
    }
  },
  "required": ["access_token"]
}
