{
  "$schema": "https://raw.githubusercontent.com/ToolJet/ToolJet/develop/plugins/schemas/manifest.schema.json",
  "title": "ServiceNow datasource",
  "description": "A schema defining ServiceNow datasource",
  "type": "api",
  "source": {
    "name": "ServiceNow",
    "kind": "servicenow",
    "exposedVariables": {
      "isLoading": false,
      "data": {},
      "rawData": {}
    },
    "customTesting": true,
    "options": {
      "instance_url": {
        "type": "string"
      },
      "username": {
        "type": "string"
      },
      "password": {
        "encrypted": true
      },
      "client_id": {
        "type": "string"
      },
      "client_secret": {
        "encrypted": true
      },
      "auth_url": {
        "type": "string"
      },
      "access_token_url": {
        "type": "string"
      },
      "scopes": {
        "type": "string"
      }
    }
  },
  "defaults": {
    "auth_type": {
      "value": "basic"
    },
    "grant_type": {
      "value": "authorization_code"
    },
    "add_token_to": {
      "value": "header"
    },
    "header_prefix": {
      "value": "Bearer "
    }
  },
  "properties": {
    "credentials": {
      "label": "Authentication",
      "key": "auth_type",
      "type": "dropdown-component-flip",
      "description": "A single select dropdown to choose credentials",
      "list": [
        {
          "value": "basic",
          "name": "Basic auth"
        },
        {
          "value": "oauth2",
          "name": "OAuth 2.0"
        }
      ],
      "commonFields": {
        "instance_url": {
          "label": "Instance URL",
          "key": "instance_url",
          "type": "text",
          "description": "https://<instance>.service-now.com"
        },
        "mcp_endpoint": {
          "label": "Action Fabric MCP endpoint",
          "key": "mcp_endpoint",
          "type": "text",
          "description": "Optional. MCP server URL or path. Blank = {instance_url}/sncapps/mcp-server/mcp/sn_mcp_server_default"
        },
        "flow_trigger_path": {
          "label": "Flow trigger path",
          "key": "flow_trigger_path",
          "type": "text",
          "description": "For the Trigger Flow op. Scripted REST resource URL or path, e.g. /api/<scope>/tooljet_flow/run"
        }
      }
    },
    "basic": {
      "username": {
        "label": "Username",
        "key": "username",
        "type": "text",
        "description": "Enter username"
      },
      "password": {
        "label": "Password",
        "key": "password",
        "type": "password",
        "description": "Enter password",
        "encrypted": true
      }
    },
    "oauth2": {
      "client_id": {
        "label": "Client ID",
        "key": "client_id",
        "type": "text",
        "description": "Enter client ID"
      },
      "client_secret": {
        "label": "Client secret",
        "key": "client_secret",
        "type": "password",
        "description": "Enter client secret",
        "encrypted": true
      },
      "auth_url": {
        "label": "Authorization URL",
        "key": "auth_url",
        "type": "text",
        "description": "ServiceNow OAuth authorize endpoint, e.g. https://<instance>.service-now.com/oauth_auth.do"
      },
      "access_token_url": {
        "label": "Access token URL",
        "key": "access_token_url",
        "type": "text",
        "description": "ServiceNow OAuth token endpoint, e.g. https://<instance>.service-now.com/oauth_token.do"
      },
      "scopes": {
        "label": "Scopes",
        "key": "scopes",
        "type": "text",
        "description": "Optional. Space-separated OAuth scopes (e.g. useraccount)"
      }
    }
  },
  "required": [
    "instance_url",
    "auth_url",
    "access_token_url"
  ]
}