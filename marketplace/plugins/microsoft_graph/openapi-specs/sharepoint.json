  "components": {
    "schemas": {
      "Site": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique identifier of the site",
            "readOnly": true
          },
          "displayName": {
            "type": "string",
            "description": "The full title of the site"
          },
          "name": {
            "type": "string",
            "description": "The URL-compatible short name of the site"
          },
          "description": {
            "type": "string",
            "description": "The descriptive text for the site",
            "nullable": true
          },
          "webUrl": {
            "type": "string",
            "description": "URL that displays the site in the browser",
            "readOnly": true
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the site was created",
            "readOnly": true
          },
          "lastModifiedDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the site was last modified",
            "readOnly": true
          },
          "siteCollection": {
            "$ref": "#/components/schemas/SiteCollection"
          },
          "root": {
            "type": "object",
            "description": "Present when this is the root site of the site collection"
          }
        }
      },
      "SiteCollection": {
        "type": "object",
        "properties": {
          "hostname": {
            "type": "string",
            "description": "The hostname of the site collection"
          },
          "dataLocationCode": {
            "type": "string",
            "description": "The geographic region code for where the data is stored"
          }
        }
      },
      "SiteCollectionResponse": {
        "type": "object",
        "properties": {
          "@odata.context": {
            "type": "string",
            "description": "The OData context URL"
          },
          "@odata.nextLink": {
            "type": "string",
            "description": "URL to retrieve the next page of results"
          },
          "@odata.count": {
            "type": "integer",
            "description": "Total count of items (when $count=true)"
          },
          "value": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Site"
            }
          }
        }
      },
      "SharePointList": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique identifier of the list",
            "readOnly": true
          },
          "displayName": {
            "type": "string",
            "description": "The displayable title of the list"
          },
          "name": {
            "type": "string",
            "description": "The URL-compatible name of the list"
          },
          "description": {
            "type": "string",
            "description": "The descriptive text for the list",
            "nullable": true
          },
          "webUrl": {
            "type": "string",
            "description": "URL that displays the list in the browser",
            "readOnly": true
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the list was created",
            "readOnly": true
          },
          "lastModifiedDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the list was last modified",
            "readOnly": true
          },
          "createdBy": {
            "$ref": "#/components/schemas/IdentitySet"
          },
          "list": {
            "$ref": "#/components/schemas/ListInfo"
          }
        }
      },
      "ListInfo": {
        "type": "object",
        "properties": {
          "hidden": {
            "type": "boolean",
            "description": "Whether the list is hidden from users"
          },
          "template": {
            "type": "string",
            "description": "The list template type",
            "enum": [
              "genericList",
              "documentLibrary",
              "survey",
              "links",
              "announcements",
              "contacts",
              "events",
              "tasks",
              "discussionBoard",
              "pictureLibrary",
              "noListTemplate"
            ]
          }
        }
      },
      "ListCollectionResponse": {
        "type": "object",
        "properties": {
          "@odata.context": {
            "type": "string",
            "description": "The OData context URL"
          },
          "@odata.nextLink": {
            "type": "string",
            "description": "URL to retrieve the next page of results"
          },
          "@odata.count": {
            "type": "integer",
            "description": "Total count of items (when $count=true)"
          },
          "value": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SharePointList"
            }
          }
        }
      },
      "CreateListRequest": {
        "type": "object",
        "required": ["displayName"],
        "properties": {
          "displayName": {
            "type": "string",
            "description": "The displayable title of the list"
          },
          "description": {
            "type": "string",
            "description": "The descriptive text for the list",
            "nullable": true
          },
          "list": {
            "$ref": "#/components/schemas/ListInfo"
          }
        }
      },
      "ListItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique identifier of the list item",
            "readOnly": true
          },
          "webUrl": {
            "type": "string",
            "description": "URL that displays the item in the browser",
            "readOnly": true
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the item was created",
            "readOnly": true
          },
          "lastModifiedDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the item was last modified",
            "readOnly": true
          },
          "createdBy": {
            "$ref": "#/components/schemas/IdentitySet"
          },
          "lastModifiedBy": {
            "$ref": "#/components/schemas/IdentitySet"
          },
          "fields": {
            "$ref": "#/components/schemas/ListItemFields"
          }
        }
      },
      "ListItemFields": {
        "type": "object",
        "description": "Column values for the list item. Property names correspond to the internal names of the list columns (e.g., Title, Status).",
        "additionalProperties": true
      },
      "ListItemCollectionResponse": {
        "type": "object",
        "properties": {
          "@odata.context": {
            "type": "string",
