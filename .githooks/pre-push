#!/usr/bin/env bash
# Pre-push hook: run the affected server unit tests before pushing.
# Opt-in once with: npm run setup:hooks
# Bypass a single push with: git push --no-verify
set -euo pipefail

# Git hooks run with a minimal environment — put the dev's node/npm on PATH
# so jest's ts-node config loader can resolve the .ts jest configs.
if [ -s "$HOME/.nvm/nvm.sh" ]; then
  # shellcheck disable=SC1091
  . "$HOME/.nvm/nvm.sh" >/dev/null 2>&1 || true
fi
command -v node >/dev/null 2>&1 || export PATH="$PATH:/usr/local/bin:/opt/homebrew/bin"

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"
exec npm run ci:changed --silent
