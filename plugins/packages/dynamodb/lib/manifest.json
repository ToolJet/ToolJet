{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DynamoDB datasource",
  "description": "A schema defining DynamoDB datasource",
  "type": "object",
  "tj:version": "1.0.0",
  "tj:source": {
    "name": "DynamoDB",
    "kind": "dynamodb",
    "type": "database"
  },
  "properties": {
    "instance_metadata_credentials": {
      "type": "string",
      "title": "Authentication",
      "description": "Select authentication method",
      "enum": ["iam_access_keys", "aws_instance_credentials", "aws_arn_role"],
      "default": "iam_access_keys"
    },
    "access_key": {
      "type": "string",
      "title": "Access key ID",
      "description": "Enter access key ID"
    },
    "secret_key": {
      "type": "string",
      "title": "Secret access key",
      "description": "Enter secret access key"
    },
    "role_arn": {
      "type": "string",
      "title": "Role ARN",
      "description": "Enter role ARN"
    },
    "region": {
      "type": "string",
      "title": "Region",
      "description": "Select AWS region",
      "enum": [
        "us-east-2",
        "us-east-1",
        "us-west-1",
        "us-west-2",
        "af-south-1",
        "ap-east-1",
        "ap-south-1",
        "ap-northeast-3",
        "ap-northeast-2",
        "ap-southeast-1",
        "ap-southeast-2",
        "ap-northeast-1",
        "ca-central-1",
        "cn-north-1",
        "cn-northwest-1",
        "eu-central-1",
        "eu-west-1",
        "eu-west-2",
        "eu-south-1",
        "eu-west-3",
        "eu-north-1",
        "me-south-1",
        "sa-east-1",
        "us-gov-east-1",
        "us-gov-west-1"
      ],
      "default": ""
    }
  },
  "tj:encrypted": ["secret_key"],
  "required": ["instance_metadata_credentials"],
  "allOf": [
    {
      "if": {
        "properties": {
          "instance_metadata_credentials": { "const": "iam_access_keys" }
        }
      },
      "then": {
        "required": ["access_key", "secret_key", "region"]
      }
    },
    {
      "if": {
        "properties": {
          "instance_metadata_credentials": { "const": "aws_instance_credentials" }
        }
      },
      "then": {
        "required": ["region"]
      }
    },
    {
      "if": {
        "properties": {
          "instance_metadata_credentials": { "const": "aws_arn_role" }
        }
      },
      "then": {
        "required": ["role_arn", "region"]
      }
    }
  ],
  "tj:ui:properties": {
    "instance_metadata_credentials": {
      "order": 1,
      "$ref": "#/properties/instance_metadata_credentials",
      "key": "instance_metadata_credentials",
      "label": "Authentication",
      "description": "Select authentication method",
      "widget": "dropdown-component-flip",
      "list": [
        { "value": "iam_access_keys", "name": "IAM Access Keys" },
        { "value": "aws_instance_credentials", "name": "AWS Instance Credentials" },
        { "value": "aws_arn_role", "name": "AWS ARN Role" }
      ]
    },
    "iam_access_keys": {
      "access_key": {
        "order": 10,
        "$ref": "#/properties/access_key",
        "key": "access_key",
        "label": "Access key ID",
        "description": "Enter access key ID",
        "widget": "text-v3",
        "required": true
      },
      "secret_key": {
        "order": 20,
        "$ref": "#/properties/secret_key",
        "key": "secret_key",
        "label": "Secret access key",
        "description": "Enter secret access key",
        "widget": "password-v3",
        "required": true,
        "help_text": "Supports workspace constants (e.g., {{constants.db_password}})"
      },
      "region": {
        "order": 30,
        "$ref": "#/properties/region",
        "key": "region",
        "label": "Region",
        "description": "Select AWS region",
        "widget": "dropdown",
        "required": true,
        "list": [
          { "name": "US East (Ohio)", "value": "us-east-2" },
