      "oauth": {
        "key": "oauth",
        "type": "react-component-oauth",
        "description": "A component for BigQuery OAuth",
        "oauth_configs": {
          "allowed_auth_types": [
            "oauth2"
          ],
          "allowed_grant_types": [
            "authorization_code"
          ],
          "allowed_field_groups": {
            "authorization_code": [
              "client_id",
              "client_secret"
            ]
          },
          "oauthTypes": {
            "required": true,
            "default_value": "custom_app",
            "editions": {
              "ce": [
                "custom_app"
              ],
              "ee": [
                "custom_app"
              ],
              "cloud": [
                "custom_app",
                "tooljet_app"
              ]
            }
          },
          "allowed_scope_field": false
        }
      }
    },
    "service_account": {
      "private_key": {
        "label": "Private key",
        "key": "private_key",
        "type": "textarea",
        "description": "Enter JSON private key for service account",
        "encrypted": true
      },
      "scope": {
        "label": "Scope",
        "key": "scope",
        "type": "text",
